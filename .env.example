# FIE v3 — Jhaveri Intelligence Platform
# Copy to .env and fill in values

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/fie_v3

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Optional API key for protecting endpoints (leave blank to disable)
FIE_API_KEY=

# Anthropic API key for Claude analysis features
ANTHROPIC_API_KEY=

# Server port (default: 8000)
PORT=8000

# Base URL of the FIE server (used by backfill_nse.py)
FIE_SERVER_URL=http://localhost:8000
