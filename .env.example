# FIE v3 — Jhaveri Intelligence Platform
# Copy to .env and fill in values

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/fie_v3

# ─── Security ────────────────────────────────────────────
FIE_API_KEY=                          # Optional: set to require X-API-Key header on API requests
CORS_ORIGINS=http://localhost:3000,http://localhost:8000  # Comma-separated allowed origins

# ─── External APIs ──────────────────────────────────────
ANTHROPIC_API_KEY=                    # Required for Claude chart analysis
TELEGRAM_BOT_TOKEN=                   # Optional: Telegram alert notifications
TELEGRAM_CHAT_ID=                     # Optional: Telegram chat target

# ─── Monitoring ──────────────────────────────────────────
SENTRY_DSN=                           # Optional: Sentry error tracking
FIE_ENVIRONMENT=production            # dev / staging / production

# ─── Server ──────────────────────────────────────────────
PORT=8000
NEXT_PUBLIC_API_URL=http://localhost:8000  # Backend URL for frontend

# ─── Backfill ────────────────────────────────────────────
FIE_SERVER_URL=http://localhost:8000   # Used by backfill scripts

# ─── Backups ─────────────────────────────────────────────
BACKUP_S3_BUCKET=fie2-backups         # S3 bucket for daily database backups
